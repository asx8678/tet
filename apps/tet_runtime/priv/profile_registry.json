        "model": {
          "profile_pin": "chat",
          "default_model": "openai/gpt-4o-mini",
          "fallback_models": ["mock/default"],
          "settings": {
            "temperature": 0.2
          }
        },
        "task": {
          "categories": ["chat", "planning", "acting"],
          "modes": ["assist", "plan"],
          "default_mode": "assist",
          "priority": "normal"
        },
        "schema": {
          "response": {
            "type": "object",
            "description": "Assistant response with optional plan and caveats for renderer adapters.",
            "additional_properties": true
