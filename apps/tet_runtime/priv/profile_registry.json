{
  "schema_version": 1,
  "profiles": {
    "tet_standalone": {
      "display_name": "Tet standalone",
      "description": "Safe local default profile for standalone CLI smoke tests and offline operation.",
      "version": "1.0.0",
      "tags": ["default", "safe", "mock"],
      "overlays": {
        "prompt": {
          "system": "You are Tet, a CLI-first coding assistant. Be concise, deterministic, and explicit about unsupported runtime actions.",
          "layers": [
            {
              "id": "standalone-boundary",
              "label": "Standalone boundary",
              "content": "Prefer read-only inspection and deterministic mock responses until a live provider/tool executor is configured."
            }
          ]
        },
        "tool": {
          "mode": "read_only",
          "allow": ["native.list_files", "native.read_file", "native.grep"],
          "deny": ["native.shell.write", "network.external"]
        },
        "model": {
          "profile_pin": "tet_standalone",
          "default_model": "mock/default",
          "fallback_models": [],
          "settings": {}
        },
        "task": {
          "categories": ["chat", "acting"],
          "modes": ["assist"],
          "default_mode": "assist",
          "priority": "normal"
        },
        "schema": {
          "response": {
            "type": "object",
            "description": "Free-form assistant response envelope for standalone operation.",
            "additional_properties": true
          }
        },
        "cache": {
          "policy": "preserve",
          "prompt": true,
          "tools": false
        }
      },
      "metadata": {
        "source": "bundled"
      }
    },
    "chat": {
      "display_name": "Chat",
